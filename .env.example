ADAM_EMAIL=adam@gmail.com
ADAM_EMAIL_PASSWORD=your-app-password
ADAM_OWNER_EMAIL=owner@gmail.com

# ADAM points at the gateway, not Ollama directly.
# The gateway transparently proxies to Ollama and logs every /api/chat call.
OLLAMA_URL=http://gateway:4000

# Both default to qwen3:8b on adam-pc (RTX 3000 has 6GB VRAM — qwen3:14b
# at Q4 doesn't fit and gets layer-offloaded to CPU, ~6× slower than 8b
# fully on the GPU). Override per-tier if you switch to a card with more VRAM.
ADAM_THINKER_MODEL=qwen3:8b
ADAM_ACTOR_MODEL=qwen3:8b
ADAM_THINKER_COST=0.008
ADAM_ACTOR_COST=0.008
ADAM_BUDGET_TOTAL=250
ADAM_BUDGET_VISIBLE=true
GIT_REMOTE_URL=
GIT_TOKEN=

# Sleep / fine-tuning. When true, Adam.Sleep writes memory/finetune_requested
# at the end of a sleep cycle. The external trainer in trainer/ watches that
# marker and runs QLoRA via Unsloth. See trainer/README.md.
ADAM_FINETUNE_ENABLED=false
# Default Ollama tag the trainer fine-tunes when no marker is present (e.g.
# during a manual --once run). Normally inherited from ADAM_THINKER_MODEL.
ADAM_BASE_MODEL=qwen3:8b

# LLM gateway dashboard — http://localhost:4000
